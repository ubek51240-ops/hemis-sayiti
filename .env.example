# Test-sinov-ucun - Environment Variables Example
# Bu faylni .env nomi bilan nusxalang va o'zingizning ma'lumotlaringiz bilan to'ldiring

# =============================================================================
# DJANGO ASOSIY SOZLAMALAR
# =============================================================================
SECRET_KEY=django-insecure-change-me-to-strong-secret-key-at-least-50-chars
DEBUG=False
PRODUCTION=True

# =============================================================================
# EMAIL SOZLAMALAR (Gmail SMTP)
# =============================================================================
# Gmail App Password olish: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Test-sinov-ucun <your-email@gmail.com>

# =============================================================================
# XAVFSIZLIK SOZLAMALARI (MUHIM!)
# =============================================================================

# Encryption key (maxfiy ma'lumotlarni shifrlash uchun)
# Kamida 32 ta belgidan iborat bo'lishi kerak
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Security contact email (xavfsizlik xabarlari uchun)
SECURITY_EMAIL=security@yourdomain.com

# Admin whitelist IPs (admin panelga kirish uchun ruxsat etilgan IP lar, vergul bilan ajrating)
# Masalan: 192.168.1.1,10.0.0.1
ADMIN_WHITELIST_IPS=

# =============================================================================
# DATABASE SOZLAMALARI (PostgreSQL tavsiya etiladi)
# =============================================================================
# SQLite o'rniga PostgreSQL ishlatish tavsiya etiladi (production uchun)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_HOST=localhost
# DB_PORT=5432

# =============================================================================
# REDIS / CACHE SOZLAMALARI (Rate limiting uchun)
# =============================================================================
# REDIS_URL=redis://localhost:6379/1

# =============================================================================
# FAILLAR SAQLASH (AWS S3 tavsiya etiladi)
# =============================================================================
# USE_S3=True
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=your-region

# =============================================================================
# BREVO (Sendinblue) EMAIL API (Alternativ email yechim)
# =============================================================================
# BREVO_API_KEY=your-brevo-api-key

# =============================================================================
# TELEGRAM BOT (Xavfsizlik xabarlari uchun)
# =============================================================================
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
